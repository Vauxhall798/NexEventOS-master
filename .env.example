# Supabase Postgres connection strings.
# Get both from: Supabase Dashboard -> Project Settings -> Database -> Connection String
#
# DATABASE_URL: "Transaction" pooler (pgbouncer, port 6543) — used by the app at runtime.
# IMPORTANT for Vercel: use the POOLED connection (port 6543, ?pgbouncer=true).
# Every serverless invocation opens its own connection; without pooling you'll
# exhaust Supabase's connection limit under any real traffic.
DATABASE_URL="postgresql://postgres.[project-ref]:[YOUR-PASSWORD]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true"

# DIRECT_URL: direct connection (port 5432) — used only by `prisma migrate`/`prisma db push`,
# since those need prepared statements that the pooler (port 6543) can't provide.
DIRECT_URL="postgresql://postgres:[YOUR-PASSWORD]@db.[project-ref].supabase.co:5432/postgres"

# --- Authentication (NextAuth) ---
# Random secret used to sign session JWTs. Generate one with: openssl rand -base64 32
NEXTAUTH_SECRET="[GENERATE-WITH-openssl-rand--base64-32]"
# Only required in production (NextAuth infers it from the request in dev).
# Set to your deployed URL, e.g. https://nexeventos.vercel.app
NEXTAUTH_URL="http://localhost:3000"

# --- File storage (Supabase Storage) ---
# Same project as DATABASE_URL above — Project Settings -> API.
NEXT_PUBLIC_SUPABASE_URL="https://[project-ref].supabase.co"
# Service role key (NOT the anon/public key) — Project Settings -> API -> service_role secret.
# Server-side only; never expose this to the browser.
SUPABASE_SERVICE_ROLE_KEY="[YOUR-SERVICE-ROLE-KEY]"
